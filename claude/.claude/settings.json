{
  "permissions": {
    "allow": [
      "Edit(~/.claude/skills/**)",
      "Edit(~/dotfiles/claude/.claude/skills/**)",
      "Write(~/.claude/skills/**)",
      "Write(~/dotfiles/claude/.claude/skills/**)",
      "Bash(git commit*)",
      "Bash(git push*)"
    ],
    "defaultMode": "auto"
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "if [ -f \"$HOME/.claude/hooks/guard-obsidian.py\" ]; then python3 \"$HOME/.claude/hooks/guard-obsidian.py\"; else exit 0; fi"
          }
        ]
      }
    ],
    "Notification": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "osascript -e 'display notification \"Claude Code needs your attention\" with title \"Claude Code\"'"
          }
        ]
      }
    ]
  },
  "enabledPlugins": {
    "obsidian@obsidian-skills": true,
    "microsoft-docs@claude-plugins-official": false,
    "document-skills@anthropic-agent-skills": true,
    "clangd-lsp@claude-plugins-official": true
  },
  "extraKnownMarketplaces": {
    "obsidian-skills": {
      "source": {
        "source": "github",
        "repo": "kepano/obsidian-skills"
      }
    },
    "anthropic-agent-skills": {
      "source": {
        "source": "github",
        "repo": "anthropics/skills"
      }
    }
  },
  "language": "Japanese",
  "advisorModel": "opus",
  "tui": "fullscreen",
  "voice": {
    "enabled": true,
    "mode": "hold"
  },
  "theme": "dark",
  "remoteControlAtStartup": false,
  "agentPushNotifEnabled": true,
  "skipAutoPermissionPrompt": true,
  "autoMode": {
    "allow": [
      "$defaults",
      "Pushing directly to the main branch is allowed: this is a personal repository where I am the sole contributor, so there is no pull request review process"
    ]
  },
  "voiceEnabled": true,
  "model": "fable"
}
