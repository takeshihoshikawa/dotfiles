{
  "permissions": {
    "defaultMode": "auto",
    "allow": [
      "Edit(~/.claude/skills/**)",
      "Edit(~/dotfiles/claude/.claude/skills/**)",
      "Write(~/.claude/skills/**)",
      "Write(~/dotfiles/claude/.claude/skills/**)",
      "Bash(git commit*)",
      "Bash(git push*)"
    ]
  },
  "autoMode": {
    "allow": [
      "$defaults",
      "Pushing directly to the main branch is allowed: this is a personal repository where I am the sole contributor, so there is no pull request review process"
    ]
  },
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "echo '{\"hookSpecificOutput\": {\"hookEventName\": \"SessionStart\", \"additionalContext\": \"セッション開始時の自動タスク: (1) Skillツールで skill=\\\"loop\\\", args=\\\"60m /check-in\\\" を実行してcheck-inのloopを起動（check-in自体はすぐ実行しないこと）、(2) /daily-reportのcronがなければCronCreateで cron=\\\"33 16 * * 1-5\\\", prompt=\\\"/daily-report recap\\\", recurring=true で設定。いずれもスキル本体は今すぐ実行しないこと（セットアップのみ）。\"}}'",
            "statusMessage": "check-in loop・日報cronをセットアップ中..."
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "[ -f \"$HOME/.claude/hooks/guard-obsidian.py\" ] && python3 \"$HOME/.claude/hooks/guard-obsidian.py\" || exit 0"
          }
        ]
      }
    ],
    "Notification": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "osascript -e 'display notification \"Claude Code needs your attention\" with title \"Claude Code\"'"
          }
        ]
      }
    ]
  },
  "enabledPlugins": {
    "obsidian@obsidian-skills": true,
    "microsoft-docs@claude-plugins-official": true,
    "document-skills@anthropic-agent-skills": true
  },
  "extraKnownMarketplaces": {
    "obsidian-skills": {
      "source": {
        "source": "github",
        "repo": "kepano/obsidian-skills"
      }
    },
    "anthropic-agent-skills": {
      "source": {
        "source": "github",
        "repo": "anthropics/skills"
      }
    }
  },
  "model": "opusplan",
  "language": "Japanese",
  "tui": "fullscreen",
  "theme": "dark",
  "remoteControlAtStartup": false,
  "agentPushNotifEnabled": true,
  "skipAutoPermissionPrompt": true,
  "voiceEnabled": true
}
